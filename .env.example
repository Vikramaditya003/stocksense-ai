# ─── AI ────────────────────────────────────────────────────────────────────────
# Get from https://console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# ─── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/forecast
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/forecast

# ─── Database (Supabase) ────────────────────────────────────────────────────────
# Get from https://supabase.com → your project → Settings → API
# IMPORTANT: Create your project in ap-south-1 (Mumbai) for lowest latency
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Rate limiting (Upstash Redis) ────────────────────────────────────────────
# Required for production — in-memory fallback is per-process only (resets on cold starts).
# Free tier at https://console.upstash.com → Create Database → REST API credentials
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ─── Site ──────────────────────────────────────────────────────────────────────
# Your production domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
